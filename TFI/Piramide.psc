Algoritmo Piramide
    Definir altura, i, j, k Como Entero
	
    Escribir "Ingrese la altura de la piramide:"
    Leer altura
	
    Para i <- 1 Hasta altura
		
        Para j <- 1 Hasta altura - i
            Escribir Sin Saltar " "
        FinPara
		
        Para k <- 1 Hasta i
            Escribir Sin Saltar k, " "
        FinPara
		
        Escribir ""
		
    FinPara
	
FinAlgoritmo